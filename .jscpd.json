{
	"threshold": 5,
	"minLines": 4,
	"minTokens": 50,
	"reporters": ["html", "json"],
	"output": "reports/jscpd",
	"ignore": [
		"**/contractions.tsx",
		"**/drizzle/**",
		"**/node_modules/**",
		"**/dist/**",
		"**/build/**",
		"**/.wrangler/**",
		"**/coverage/**",
		"**/reports/**",
		"**/*.d.ts"
	],
	"absolute": true,
	"gitignore": true,
	"languages": ["typescript", "typescriptreact"]
}
