{
	"threshold": 1,
	"minLines": 4,
	"minTokens": 100,
	"reporters": [
		"html",
		"json"
	],
	"output": "reports/jscpd",
	"ignore": [
		"**/.claude/**",
		"**/contractions.tsx",
		"**/drizzle/**",
		"**/node_modules/**",
		"**/dist/**",
		"**/build/**",
		"**/coverage/**",
		"**/reports/**",
		"**/*.d.ts"
	],
	"absolute": true,
	"gitignore": true,
	"format": [
		"typescript",
		"tsx"
	]
}
